@page
@model ControleHoras.Pages.LancamentosModel

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header">
            <h2 class="mb-0">Controle de Horas</h2>
        </div>

        <div class="card-body">

            <form method="get" class="row g-2 align-items-end mb-3">

                <div class="col-md-3">
                    <label>Data</label>

                    <input type="date"
                        asp-for="DataSelecionada"
                        class="form-control"
                        max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-auto">
                    <button type="submit"
                            class="btn btn-primary">
                        Carregar
                    </button>
                </div>

            </form>

           @if (Model.RegistroHoje == null)
            {
                <div class="alert alert-danger">
                    RegistroHoje está NULL
                </div>
            }
            else
            {
                <div class="alert alert-light py-2 mb-3">

                    <div>
                        <strong>
                            @Model.RegistroHoje.Data.ToShortDateString()
                        </strong>
                    </div>

                    <small class="text-muted">
                        Próxima ação:
                        <strong>
                            @Model.RegistroHoje.ProximaAcao()
                        </strong>
                    </small>

                </div>
            }

            @if (!string.IsNullOrEmpty(Model.MensagemErro))
            {
                <div class="alert alert-danger">
                    @Model.MensagemErro
                </div>
            }

            <form method="post" class="mb-4">

                <input type="hidden"
                    asp-for="DataSelecionada" />

                <button class="btn btn-primary btn-sm">
                    Registrar Agora
                </button>

                <button class="btn btn-outline-secondary btn-sm">
                    Desfazer Última Batida
                </button>

            </form>

            <hr />

            <h4>Batidas de Hoje</h4>

            <form method="post">

                <div class="row">

                    <div class="col-md-6">
                        Entrada manhã
                        <input type="time"
                           class="form-control"
                           name="EntradaManha"
                           value="@Model.RegistroHoje.EntradaManha?.ToString(@"hh\:mm")" />
                    </div>

                    <div class="col-md-6">
                        Saída almoço
                        <input type="time"
                           class="form-control"
                           name="SaidaManha"
                           value="@Model.RegistroHoje.SaidaManha?.ToString(@"hh\:mm")" />
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6">
                        Retorno almoço
                        <input type="time"
                           class="form-control"
                           name="EntradaTarde"
                           value="@Model.RegistroHoje.EntradaTarde?.ToString(@"hh\:mm")" />
                    </div>

                    <div class="col-md-6">
                        Saída dia
                        <input type="time"
                           class="form-control"
                           name="SaidaTarde"
                           value="@Model.RegistroHoje.SaidaTarde?.ToString(@"hh\:mm")" />
                    </div>

                </div>

                <div class="mt-3">
                    
                    <input type="hidden"
                        asp-for="DataSelecionada" />
                    
                    <button type="submit"
                            asp-page-handler="SalvarHorarios"
                            class="btn btn-success">
                        Salvar Ajustes
                    </button>

                </div>

            </form>

            <hr />

            <div class="card bg-light">

                <div class="card-body">

                    <h3>Observações</h3>

                    <form method="post">

                        <input type="hidden"
                            asp-for="DataSelecionada" />

                        <textarea
                            name="Observacao"
                            class="form-control"
                            rows="3">@Model.RegistroHoje.Observacao</textarea>

                        <br />

                        <button
                            type="submit"
                            asp-page-handler="SalvarObservacao"
                            class="btn btn-secondary">
                            Salvar Observação
                        </button>

                    </form>

                    <hr />

                    <h4>Resumo do Dia</h4>

                    <div class="row text-center">

                        <div class="col-md-3">
                            <small class="text-muted d-block">
                                Total Trabalhado
                            </small>

                            <strong>
                                @Model.RegistroHoje.TotalFormatado()
                            </strong>
                        </div>

                        <div class="col-md-3">
                            <small class="text-muted d-block">
                                Meta Diária
                            </small>

                            <strong>
                                <strong>
                                    @Model.MetaDiariaFormatada
                                </strong>
                            </strong>
                        </div>

                        <div class="col-md-3">
                            <small class="text-muted d-block">
                                Banco de Horas
                            </small>

                            @if (Model.SaldoAcumulado > TimeSpan.Zero)
                            {
                                <strong class="text-success">
                                    +@Model.SaldoAcumulado.ToString(@"hh\:mm")
                                </strong>
                            }
                            else if (Model.SaldoAcumulado < TimeSpan.Zero)
                            {
                                <strong class="text-danger">
                                    -@Model.SaldoAcumulado.Duration().ToString(@"hh\:mm")
                                </strong>
                            }
                            else
                            {
                                <strong>00:00</strong>
                            }
                        </div>

                        <div class="col-md-3">
                            <small class="text-muted d-block">
                                Status
                            </small>

                            @if (Model.RegistroHoje.DiaEncerrado())
                            {
                                <strong>
                                    @Model.RegistroHoje.SaldoFormatado(Model.JornadaHoras)
                                </strong>
                            }
                            else
                            {
                                <strong class="text-warning">
                                    Em andamento
                                </strong>
                            }
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>